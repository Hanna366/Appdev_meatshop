# Copy this file to .env and fill values. Do NOT commit .env with secrets.
# Path to service account JSON file (preferred)
SERVICE_ACCOUNT_PATH=./service-account.json

# OR (alternative) paste the entire service account JSON as a single-line string
# SERVICE_ACCOUNT_JSON={"type":"service_account", ... }

# Google reCAPTCHA v2 Site Key
EXPO_PUBLIC_RECAPTCHA_SITE_KEY=6LeB8MosAAAAAMHtWhcJoruXfxkUTTN96Sxeh_r7

# Google OAuth Configuration for Expo Auth Session
# Get these from Google Cloud Console
EXPO_PUBLIC_GOOGLE_CLIENT_ID=YOUR_WEB_CLIENT_ID_HERE.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=YOUR_ANDROID_CLIENT_ID_HERE.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=YOUR_IOS_CLIENT_ID_HERE.apps.googleusercontent.com
