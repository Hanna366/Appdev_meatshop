rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function getUser() {
      return isSignedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : null;
    }

    function hasTenant(tid) {
      let u = getUser();
      return isSignedIn() && u != null && u.tenantId == tid;
    }

    function tenantIsAdmin(tid) {
      let u = getUser();
      return isSignedIn()
        && u != null
        && u.tenantId == tid
        && (u.role == 'admin' || u.role == 'owner');
    }

    // Tenant products: tenant members can read, admins can write
    match /tenants/{tenantId}/products/{productId} {
      // validate product shape and simple constraints
      function isValidProduct() {
        return request.resource.data.name is string
          && request.resource.data.unit is string
          && request.resource.data.type is string
          && request.resource.data.price is number
          && request.resource.data.stock is number
          && request.resource.data.price >= 0
          && request.resource.data.stock >= 0
          // if `id` field exists, it must match the document id
          && ( !('id' in request.resource.data) || request.resource.data.id == productId )
          // if `tenantId` field exists, it must match the path tenantId
          && ( !('tenantId' in request.resource.data) || request.resource.data.tenantId == tenantId );
      }

      // reads allowed for any signed-in member of the tenant
      allow read: if hasTenant(tenantId);

      // create only by tenant admin and must pass validation and reference the same tenant
      allow create: if tenantIsAdmin(tenantId)
        && isValidProduct()
        && ( !('tenantId' in request.resource.data) || request.resource.data.tenantId == tenantId );

      // update only by tenant admin and must pass validation
      allow update: if tenantIsAdmin(tenantId)
        && isValidProduct();

      // delete only by tenant admin
      allow delete: if tenantIsAdmin(tenantId);
    }

    // Simple user profile access (user can manage their own profile)
    match /users/{userId} {
      allow read, create, update: if isSignedIn() && request.auth.uid == userId;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
